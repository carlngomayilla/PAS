APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pas_anbg
DB_USERNAME=pas_user
DB_PASSWORD=
DB_SSLMODE=prefer
DB_CONNECT_TIMEOUT=3
DB_LOGIN_PREFLIGHT=true
DB_LOGIN_PREFLIGHT_TIMEOUT=1

# SQLite rapide pour une demo locale uniquement :
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_PASSWORD_EXPIRE_DAYS=90
SECURITY_PASSWORD_HISTORY_SIZE=5
SECURITY_PASSWORD_REQUIRE_LETTERS=true
SECURITY_PASSWORD_REQUIRE_MIXED_CASE=false
SECURITY_PASSWORD_REQUIRE_NUMBERS=true
SECURITY_PASSWORD_REQUIRE_SYMBOLS=false
SECURITY_PASSWORD_CHECK_PWNED=true

# Compte bootstrap administrateur fonctionnel cree par ProductionSafeSeeder.
ADMIN_FONCTIONNEL_EMAIL=c.ngomayila.anbg@gmail.com
ADMIN_FONCTIONNEL_NAME="Administrateur fonctionnel"
# Optionnel : si vide, un mot de passe temporaire aleatoire est genere et affiche au seed.
ADMIN_FONCTIONNEL_INITIAL_PASSWORD=

SECURITY_ENCRYPT_JUSTIFICATIFS=true
ANTIVIRUS_SCAN_ENABLED=false
ANTIVIRUS_BINARY=clamscan
ANTIVIRUS_ARGUMENTS=--no-summary
ANTIVIRUS_TIMEOUT=30
ANTIVIRUS_FAIL_OPEN=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=brevo
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="ANBG · e-Pilotage PAS"

# ─── Canal email Brevo (v1.1) ────────────────────────────────────────────
# Canal COMPLÉMENTAIRE au canal in_app. Aucun envoi tant que BREVO_ENABLED=false.
# Un échec d'envoi Brevo ne bloque JAMAIS le workflow métier (fail-safe).
#
# DEUX TRANSPORTS DISPONIBLES :
#   api  : POST https://api.brevo.com/v3/smtp/email — auth par BREVO_API_KEY
#          ✓ Pas de restriction d'IP, plus rapide. RECOMMANDÉ.
#   smtp : Relais SMTP smtp-relay.brevo.com:587 — auth user/pass
#          ⚠️ Soumis aux IPs autorisées dans le compte Brevo.
BREVO_ENABLED=true
BREVO_TRANSPORT=api
BREVO_API_KEY=                              # xkeysib-... (https://app.brevo.com/settings/keys/api)
BREVO_API_ENDPOINT=https://api.brevo.com/v3/smtp/email
BREVO_API_TIMEOUT=10
# ⚠️ NE JAMAIS METTRE `false` EN PRODUCTION. Bypass dev local Windows uniquement
#    (PHP sans bundle CA → cURL error 60). En prod, laisser `true`.
BREVO_API_VERIFY_SSL=true

# Credentials SMTP — utilisés uniquement si BREVO_TRANSPORT=smtp (fallback)
BREVO_MAILER=brevo
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587
BREVO_SCHEME=smtp
BREVO_USERNAME=
BREVO_PASSWORD=

# Expéditeur (commun aux deux transports)
BREVO_FROM_ADDRESS=no-reply@example.test
BREVO_FROM_NAME="ANBG · e-Pilotage PAS"
# Queue Brevo : laisser default si le worker prod ecoute la queue standard.
BREVO_QUEUE_CONNECTION=database
BREVO_QUEUE=default

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PLATFORM_SETTINGS_DATABASE=true

# ─── IA PTA / rapports ─────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
AI_KNOWLEDGE_ROOT=storage/app/ai/knowledge
AI_TRAINING_ROOT=storage/app/ai/training
AI_PTA_AGENT_REFERENCE_PATH=docs/codes_agent_anbg_import.xlsx
AI_PTA_IMPORT_TEMPLATE_PATH=docs/modele_import_global_pas_pao_pta.xlsx
AI_PTA_QUARTERLY_REPORT_TEMPLATE_PATH=docs/templates/rapport_pta_trimestriel_2026.docx
AI_PTA_WINDOWS_OCR_ENABLED=true
AI_PTA_WINDOWS_OCR_SCRIPT_PATH=scripts/ocr/windows_pdf_ocr.ps1
AI_PTA_WINDOWS_OCR_MAX_PAGES=0
AI_PTA_WINDOWS_OCR_RENDER_WIDTH=2600
AI_PTA_WINDOWS_OCR_TIMEOUT=900
